---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = { title: 'About Us | SSS Health Solutions' };

const leadership = [
  {
    name: 'Mobinu Shadhin',
    title: 'Founder & Principal Agent',
    phone: '727-291-3930',
    image: '/head.png',
    imageClass: 'object-cover w-full h-full object-top scale-110', 
    description: 'Specializing in high-stakes sales and behavioral psychology to deliver private, under-65 health plans that truly fit the client.',
  },
  {
    name: 'Jefferson Shafin',
    title: 'Senior Health Advisor',
    phone: '561-985-6493',
    image: '/head2.png',
    imageClass: 'object-cover w-full h-full object-[center_15%] scale-[1.35]', 
    description: 'Expert health advisor specializing in comprehensive, multi-state coverage strategies and a dedicated, client-first approach.',
  },
  {
    name: 'Munem Shadh',
    title: 'Managing Partner & Advisor',
    phone: '954-270-1242',
    image: '/head3.png',
    imageClass: 'object-cover w-full h-full object-top scale-110', 
    description: 'Driving strategic client growth and specializing in structuring long-term, premium health portfolios for individuals and families.',
  }
];

const support = [
  {
    name: 'Sarah Winchester',
    title: 'Executive Assistant',
    phone: '727-304-5971',
    image: '/head4.png',
    imageClass: 'object-cover w-full h-full object-center', 
    description: 'Ensuring seamless operations, swift client onboarding, and dedicated administrative support for the entire advisory team.',
  }
];
---

<Layout metadata={metadata}>
  <Hero
    tagline="Our Story"
    title="Built on Family. Driven by Integrity."
    subtitle="SSS Health Solutions was founded by brothers who saw a flaw in the health insurance industry. We built this independent agency to provide genuine advisory over high-pressure sales."
  />

  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-7xl">
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start mb-12">
      {leadership.map((member) => (
        <div class="flex flex-col items-center text-center p-6 border border-gray-200 dark:border-slate-800 rounded-xl shadow-sm bg-white dark:bg-slate-900 h-full">
          <div class="relative w-48 h-48 mb-6 overflow-hidden rounded-full border-4 border-secondary shadow-md">
            <img 
              src={member.image} 
              alt={member.name} 
              class={member.imageClass}
            />
          </div>
          <h2 class="text-2xl font-bold dark:text-white mb-1">{member.name}</h2>
          <p class="text-secondary font-semibold mb-2">{member.title}</p>
          <a 
            href={`tel:${member.phone.replace(/-/g, '')}`} 
            class="text-blue-600 dark:text-blue-400 font-medium hover:underline mb-4 flex items-center gap-2 transition duration-200"
          >
            📞 {member.phone}
          </a>
          <p class="text-muted dark:text-slate-400 text-sm leading-relaxed italic">
            "{member.description}"
          </p>
        </div>
      ))}
    </div>

    <div class="w-full max-w-3xl mx-auto h-px bg-gray-200 dark:bg-slate-800 my-12"></div>

    <div class="flex justify-center">
      <div class="w-full max-w-sm">
        {support.map((member) => (
          <div class="flex flex-col items-center text-center p-6 border border-gray-100 dark:border-slate-800/50 rounded-xl bg-gray-50 dark:bg-slate-800/20 h-full">
            <div class="relative w-40 h-40 mb-6 overflow-hidden rounded-full border-2 border-gray-300 dark:border-slate-600 shadow-sm">
              <img 
                src={member.image} 
                alt={member.name} 
                class={member.imageClass}
              />
            </div>
            <h2 class="text-xl font-bold dark:text-white mb-1">{member.name}</h2>
            <p class="text-secondary font-medium mb-2">{member.title}</p>
            <a 
              href={`tel:${member.phone.replace(/-/g, '')}`} 
              class="text-blue-600 dark:text-blue-400 font-medium hover:underline mb-4 flex items-center gap-2 transition duration-200"
            >
              📞 {member.phone}
            </a>
            <p class="text-muted dark:text-slate-400 text-sm leading-relaxed italic">
              "{member.description}"
            </p>
          </div>
        ))}
      </div>
    </div>

  </section>

  <section class="bg-blue-50 dark:bg-slate-800 py-12 px-4 mb-16 rounded-lg max-w-6xl mx-auto">
    <div class="text-center">
      <h3 class="text-xl font-bold mb-4">Our National Coverage</h3>
      <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed max-w-4xl mx-auto">
        Active in: AL, AR, CA, CO, DE, FL, GA, IA, ID, IL, IN, KS, LA, MD, MI, MO, MS, MT, NC, NV, NY, OH, OK, SC, SD, TN, TX, UT, VA, WI, WV, WY.
      </p>
    </div>
  </section>

  <CallToAction
    title="Ready to find a plan?"
    actions={[{ variant: 'primary', text: 'Contact Us', href: '/contact' }]}
  />
</Layout>
