---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = { title: 'About Us | SSS Health Solutions' };
---

<Layout metadata={metadata}>
  <Hero
    tagline="Our Story"
    title="Built on Family. Driven by Integrity."
    subtitle="SSS Health Solutions was founded by brothers who saw a flaw in the health insurance industry. We built this independent agency to provide genuine advisory over high-pressure sales."
  />

  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <div>
         <img src="/src/assets/images/head.png" alt="Mobinu Shadhin" class="rounded-lg shadow-lg w-full h-auto" />
      </div>
      <div>
        <h2 class="text-3xl font-bold mb-4 dark:text-white">Mobinu Shadhin</h2>
        <p class="text-lg text-secondary font-semibold mb-4">Founder & Principal Agent (NPN: 21430983)</p>
        <p class="text-muted dark:text-slate-400">
          As the principal agent, Mobinu brings a unique background in high-stakes sales and behavioral psychology to the insurance world. His focus is on navigating complex regulatory frameworks to deliver private, under-65 health plans that truly fit the client.
        </p>
      </div>
    </div>
  </section>

  <CallToAction
    title="Ready to find a plan?"
    actions={[{ variant: 'primary', text: 'Contact Us', href: '/contact' }]}
  />
</Layout>
