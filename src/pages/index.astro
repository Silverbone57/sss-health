---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'SSS Health Solutions | Private Health Insurance Experts',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      { variant: 'primary', text: 'Get a Free Consultation', href: '/contact', icon: 'tabler:clipboard-check' },
      { text: 'Explore Services', href: '#features' },
    ]}
    image={{
      src: '~/assets/images/sss-logo-title.png',
      alt: 'SSS Health Solutions - Maximum Coverage and Affordability',
    }}
  >
    <Fragment slot="title">
      Navigate Your Health Coverage with <span class="text-secondary dark:text-white highlight">Confidence</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">SSS Health Solutions LLC</span> is an independent agency specializing in Under-65 Private Health Insurance. We bridge the gap between complex policies and your peace of mind. Proudly partnered with top-tier carriers to serve clients across several states.
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="Our Services"
    title="Insurance tailored to you."
    items={[
      { title: 'Individual & Family Plans', description: 'Comprehensive coverage designed to protect your health and your budget.', icon: 'tabler:users' },
      { title: 'Private Network Health (PPO)', description: 'Access elite nationwide networks through carriers like UHC and LifeX.', icon: 'tabler:shield-check' },
      { title: 'Expert Plan Matching', description: 'Unbiased advisory to find the exact right policy for your specific needs.', icon: 'tabler:adjustments-horizontal' },
    ]}
  />

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Clear answers to help you make informed decisions about your coverage."
    items={[
      { title: 'When can I enroll?', description: 'Right now. Our private plans are available 365 days a year—no need to wait for Open Enrollment.' },
      { title: 'Does it cost anything to use your agency?', description: 'No. Our advisory services are 100% free to you. We are compensated directly by the insurance carriers when we find you a plan.' },
      { title: 'Do you offer both Private and ACA (Obamacare) plans?', description: 'Yes. We offer a full spectrum of options. While we specialize in medically underwritten private plans, we also write comprehensive ACA (Marketplace) coverage. Our goal is to find the exact right fit for your specific health needs and budget.' },
      { title: 'How long does it take to get a quote?', description: 'Once we have a brief consultation to assess your needs, we can typically match you with the right plan and generate an accurate quote the exact same day.' },
    ]}
  />

  <CallToAction
    actions={[{ variant: 'primary', text: 'Contact Us Today', href: '/contact', icon: 'tabler:mail' }]}
  >
    <Fragment slot="title">Ready to secure your health coverage?</Fragment>
  </CallToAction>
</Layout>
