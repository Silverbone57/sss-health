---
import '@fontsource-variable/inter';
---

<style is:inline is:global>
  :root {
    --aw-color-primary: rgb(30 41 59);
    --aw-color-secondary: rgb(180 160 100);
    --aw-color-accent: rgb(148 163 184);
    
    --aw-color-text-heading: rgb(15 23 42);
    --aw-color-text-default: rgb(30 41 59);
    --aw-color-text-muted: rgb(30 41 59 / 70%);
    --aw-color-bg-page: rgb(255 255 255);
    --aw-color-bg-page-dark: rgb(10 10 10);
  }

  .dark {
    --aw-color-primary: rgb(226 232 240);
    --aw-color-secondary: rgb(180 160 100);
    --aw-color-accent: rgb(148 163 184);
    
    --aw-color-text-heading: rgb(255 255 255);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(226 232 240 / 70%);
    --aw-color-bg-page: rgb(10 10 10);
  }
</style>
